function prettyName(filename) {
  return filename
    .replace(/\.jar$/i, '')
    .replace(/[_+]/g, ' ')
    .replace(/-/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function modEntry(filename) {
  return {
    id: `generated.forgemod:${filename}@jar`,
    name: prettyName(filename),
    type: 'ForgeMod',
    artifact: {
      url: RAW_MOD_BASE + encodeURIComponent(filename)
    }
  };
}

const distro = JSON.parse(fs.readFileSync(INPUT, 'utf8'));

if (!Array.isArray(distro.servers) || distro.servers.length === 0) {
  throw new Error('distribution.json ne contient aucun serveur.');
}

// On récupère le serveur 1.20.1 existant pour conserver TOUT le bloc Forge généré.
const sourceServer =
  distro.servers.find(s => s.minecraftVersion === MC_VERSION) ||
  distro.servers.find(s =>
    Array.isArray(s.modules) &&
    s.modules.some(m =>
      m?.type === 'ForgeHosted' &&
      typeof m?.id === 'string' &&
      m.id.includes('1.20.1-47.2.0')
    )
  );

if (!sourceServer) {
  throw new Error('Impossible de trouver un serveur source Forge 1.20.1 dans distribution.json');
}

const forgeModules = (sourceServer.modules || []).filter(m => m.type === 'ForgeHosted');

if (forgeModules.length === 0) {
  throw new Error('Aucun module ForgeHosted trouvé dans le serveur source.');
}

const output = {
  version: '1.0.0',
  rss: '',
  discord: {
    clientId: '1496615032207839494',
    smallImageText: 'Joue à Orion',
    smallImageKey: 'luxia'
  },
  servers: [
    {
      id: SERVER_ID,
      name: SERVER_NAME,
      description: SERVER_DESCRIPTION,
      icon: null,
      version: '1.0.0',
      address: SERVER_ADDRESS,
      minecraftVersion: MC_VERSION,
      mainServer: true,
      autoconnect: false,
      modules: [
        ...forgeModules,
        ...modFiles.map(modEntry)
      ]
    }
  ]
};

fs.writeFileSync(OUTPUT, JSON.stringify(output, null, 2) + '\n', 'utf8');

console.log(`✅ ${OUTPUT} créé.`);
